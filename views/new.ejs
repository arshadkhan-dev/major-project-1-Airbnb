
<% layout("/layouts/boilerplate") %>
    
    <div class="row">
        <div class="col-8 offset-2">
            <h2>Create New Listing</h2>
    <form method="post" action="/listings">
        <div class="mb-2"> 
        <label for="title" class="form-label">Title</label>
        <input type="text" name="listing[title]" id="title" placeholder="enter title" class="form-control">
        </div>

        <div class="mb-2">
        <label for="description" class="form-label">Description</label>
        <textarea name="listing[description]" id="description" class="form-control"></textarea>
        </div>

        <div class="mb-2">
        <label for="image" class="form-label">Image URL/Link</label>
        <input type="text" name="listing[image]" id="image" placeholder="enter image URL/Link" class="form-control">
        </div>
    <div class="row">
        <div class="mb-2 col-md-4">
            <label for="price" class="form-label">Price</label>
        <input type="number" name="listing[price]" id="price" placeholder="enter price" class="form-control">
        </div>

        <div class="mb-2 col-md-8">
        <label for="location" class="form-label">Location</label>
        <input type="text" name="listing[location]" id="location" placeholder="enter location" class="form-control">
        </div>

        </div>

        <div class="mb-2">
            <label for="country" class="form-label">Country</label>
        <input type="text" name="listing[country]" id="country" placeholder="enter country" class="form-control">
        </div>

        <button class="btn btn-dark add-btn">Add</button>
        <br> <br>
    </form>
    </div>
</div>
