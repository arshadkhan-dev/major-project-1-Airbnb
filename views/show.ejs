<% layout('/layouts/boilerplate') -%>

<div class="row">
     <div class="col-8 offset-3">
     <h3>Listing Details</h3>
      </div>

     <div class="card col-6 offset-3 mt-3 show-card">
     <img src="<%=listing.image%>" class="card-img-top show-img" alt="listing-image">
     <div class="card-body">
      <p class="card-text">
          <b> <%= listing.title %> </b> <br>
          <%= listing.description %>    <br>
          PKR:<%= listing.price.toLocaleString("en-PK") %> <br>
          <%= listing.location %>  <br>
          <%= listing.country %>   <br>
     </p>
     </div>
     </div>
    
     <div class="btns col-6 offset-3">
     <form method="get" action="/listings/<%= listing.id %>/edit">
          <button class="btn btn-dark edit-btn">Edit</button>
     </form>
     <form method="post" action="/listing/<%=listing._id%>/delete?_method=DELETE">
          <button class="btn btn-dark offset-2">Delete</button>
     </form>
     </div>   

     <br> <br>
</div>